# OCR App Environment Variables

# --- LLM API (existing) ---
API_MODE=openrouter
GOOGLE_API_KEY=
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemini-3-flash-preview

# --- Odoo CRM (new) ---
ODOO_URL=https://crm.triindia.in
ODOO_DB=triindia
ODOO_USERNAME=ocr_sync@triindia.in
ODOO_API_KEY=your_odoo_api_key_here

# Optional: disable Odoo sync entirely if needed
# ODOO_SYNC_ENABLED=true
